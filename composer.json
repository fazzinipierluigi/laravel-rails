{
    "name": "fazzinipierluigi/laravel-rails",
    "description": "A Laravel package to create and execute workflows (rails) inside your app",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierluigi Fazzini",
            "email": "fazzinipierluigi@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/fazzinipierluigi/laravel-rails",
    "keywords": ["Laravel", "LaravelRails", "workflow", "state-machine"],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "jwadhams/json-logic-php": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fazzinipierluigi\\LaravelRails\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fazzinipierluigi\\LaravelRails\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fazzinipierluigi\\LaravelRails\\LaravelRailsServiceProvider"
            ],
            "aliases": {
                "LaravelRails": "Fazzinipierluigi\\LaravelRails\\Facades\\LaravelRails"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
